# ──────────────────────────────────────────────────────────────
# .env.example — QuantumEnergyOS
#
# ⚠️  ESTE ARCHIVO ES UNA PLANTILLA — NO CONTIENE SECRETOS REALES
# Copia a .env y rellena los valores:
#   cp .env.example .env
#
# .env está en .gitignore — NUNCA lo subas al repositorio.
# ──────────────────────────────────────────────────────────────

# ── Entorno ───────────────────────────────────────────────────
QEOS_ENV=development          # development | staging | production

# ── Seguridad JWT ─────────────────────────────────────────────
# Generar con: openssl rand -hex 32
QEOS_JWT_SECRET=CHANGE_ME_BEFORE_DEPLOY
QEOS_JWT_EXPIRY_HOURS=24

# ── Rate Limiting ─────────────────────────────────────────────
QEOS_RATE_LIMIT_REQ=60        # requests por ventana
QEOS_RATE_LIMIT_WIN=60        # segundos por ventana

# ── API ───────────────────────────────────────────────────────
QEOS_PORT=8000
QEOS_HOST=0.0.0.0
QEOS_LOG_LEVEL=INFO           # DEBUG | INFO | WARNING | ERROR

# ── Azure Quantum (opcional) ──────────────────────────────────
AZURE_QUANTUM_SUBSCRIPTION_ID=
AZURE_QUANTUM_RESOURCE_GROUP=
AZURE_QUANTUM_WORKSPACE_NAME=
AZURE_QUANTUM_LOCATION=eastus

# ── IBM Quantum (opcional) ────────────────────────────────────
IBMQ_TOKEN=

# ── Base de datos (si se agrega persistencia) ─────────────────
# DATABASE_URL=postgresql://user:pass@localhost:5432/qeos

# ── Redis (rate limiting en producción) ───────────────────────
# REDIS_URL=redis://localhost:6379/0
